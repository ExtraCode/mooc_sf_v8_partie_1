{% extends 'base.html.twig' %}

{% block title %}Inscrivez vous sur LocaJeu{% endblock %}

{% block body %}

    <section class="container">
        {{ form_start(form) }}

        <div class="row">
            <div class="col-4">
                {{ form_row(form.email) }}
            </div>

            <div class="col-4">
                {{ form_row(form.prenom) }}
            </div>

            <div class="col-4">
                {{ form_row(form.nom) }}
            </div>

            <div class="col-4">
                {{ form_row(form.password) }}
            </div>
        </div>

        <button type="submit" class="btn btn-success">Inscription</button>

        {{ form_end(form) }}
    </section>

{% endblock %}



